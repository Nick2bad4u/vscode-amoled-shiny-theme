{
  "name": "amoled-shiny",
  "displayName": "AMOLED Shiny",
  "description": "A polished AMOLED black theme derived from AMOLED Black Shiny with Nick's workbench colors baked in.",
  "version": "0.0.1",
  "publisher": "Nick2bad4u",
  "license": "MIT",
  "packageManager": "npm@11.15.0",
  "author": {
    "name": "Nick2bad4u",
    "url": "https://github.com/Nick2bad4u"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nick2bad4u/vscode-amoled-shiny-theme.git"
  },
  "homepage": "https://github.com/Nick2bad4u/vscode-amoled-shiny-theme#readme",
  "bugs": {
    "url": "https://github.com/Nick2bad4u/vscode-amoled-shiny-theme/issues"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "amoled",
    "black",
    "dark",
    "shiny"
  ],
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "contributes": {
    "themes": [
      {
        "label": "AMOLED Shiny",
        "uiTheme": "vs-dark",
        "path": "./themes/amoled-shiny-color-theme.json"
      },
      {
        "label": "AMOLED Shiny Codex",
        "uiTheme": "vs-dark",
        "path": "./themes/amoled-shiny-codex-color-theme.json"
      },
      {
        "label": "AMOLED Shiny Codex 2",
        "uiTheme": "vs-dark",
        "path": "./themes/amoled-shiny-codex-2-color-theme.json"
      },
      {
        "label": "AMOLED Shiny Codex 3",
        "uiTheme": "vs-dark",
        "path": "./themes/amoled-shiny-codex-3-color-theme.json"
      },
      {
        "label": "AMOLED Shiny Codex 4",
        "uiTheme": "vs-dark",
        "path": "./themes/amoled-shiny-codex-4-color-theme.json"
      },
      {
        "label": "AMOLED Shiny Codex 5",
        "uiTheme": "vs-dark",
        "path": "./themes/amoled-shiny-codex-5-color-theme.json"
      }
    ]
  },
  "scripts": {
    "generate": "node ./scripts/generate-theme.mjs",
    "validate:theme": "node ./scripts/validate-theme.mjs",
    "validate:package": "vsce ls --tree",
    "validate": "npm run generate && npm run validate:theme && npm run validate:package",
    "package": "vsce package --out ./amoled-shiny-0.0.1.vsix",
    "install:code": "code --install-extension ./amoled-shiny-0.0.1.vsix --force",
    "install:insiders": "code-insiders --install-extension ./amoled-shiny-0.0.1.vsix --force",
    "open:dev": "code-insiders --extensionDevelopmentPath=%cd% ."
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1",
    "jsonc-parser": "^3.3.1",
    "plist": "^5.0.0"
  }
}
